# Brainy Prospect — variáveis de ambiente (web/Railway)
# Copie como .env e ajuste.

# --- Banco de dados ---
# Railway/Heroku: sobrescrever automaticamente.
# Vazio = usa SQLite local em $BRAINY_DATA_DIR (default ~/.brainyprospect).
DATABASE_URL=

# --- Diretório de dados (logs, exports, sqlite) ---
# Em Railway use um volume persistente: BRAINY_DATA_DIR=/data
BRAINY_DATA_DIR=

# --- Chave secreta JWT (OBRIGATÓRIA em produção) ---
# Gere com: python -c "import secrets;print(secrets.token_urlsafe(64))"
SECRET_KEY=troque-isto-em-producao

# --- Admin bootstrap (criado/promovido no startup) ---
ADMIN_EMAIL=giovannesartor@gmail.com
ADMIN_PASSWORD=Giotop12@
ADMIN_NAME=Giovanne Sartor
# Coloque 1 para FORÇAR reset da senha do admin no próximo deploy
BRAINY_ADMIN_RESET_PASSWORD=0

# --- IA ---
# Pode definir aqui (lido pelo app) ou via painel admin.
# DEEPSEEK_API_KEY=
# OPENAI_API_KEY=

# --- CORS (separar por vírgula). Use * em dev. ---
CORS_ORIGINS=*

# --- Porta (Railway define automaticamente) ---
PORT=8000
